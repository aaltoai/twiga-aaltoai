# Twiga requires these environment variables.
# Copy this file to .env and fill in the values.

# --- Required by Twiga core ---
# Postgres database URL
DATABASE_USER=postgres
DATABASE_PASSWORD=mysecurepassword
DATABASE_NAME=twiga_db
DATABASE_URL=postgresql+asyncpg://postgres:mysecurepassword@localhost:5432/twiga_db

# Meta API credentials
META_API_VERSION="v22.0"
META_APP_ID="placeholder"
META_APP_SECRET="placeholder"
WHATSAPP_CLOUD_NUMBER_ID="placeholder"
WHATSAPP_VERIFY_TOKEN="placeholder"
WHATSAPP_API_TOKEN="placeholder"

# --- LLM settings ---
LLM_PROVIDER=together          # TOGETHER | OPENAI | OLLAMA | MODAL | GOOGLE
LLM_API_KEY=
LLM_MODEL_NAME=Qwen/Qwen3-235B-A22B-Instruct-2507-tput

# --- Embedding settings ---
EMBEDDING_PROVIDER=together     # TOGETHER | OPENAI | OLLAMA | MODAL
EMBEDDING_API_KEY=

# --- Optional ---
MOCK_WHATSAPP=true
AGENTIC_MODE_ENABLED=true
