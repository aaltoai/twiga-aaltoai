# =============================================================================
# Evaluation pipeline (evaluation.py + metrics/)
# =============================================================================

# OpenAI — judge LLM + embeddings used by evaluation.py
# (read implicitly by the openai SDK and ragas)
OPENAI_API_KEY=

# Anthropic — used by testset_generation/testset_generation.py (ChatAnthropic)
ANTHROPIC_API_KEY=

# DeepSeek — used by answer_generation/cleaners.py and
# testset_generation/remake_question.py
DEEPSEEK_API_KEY=


# =============================================================================
# Answer generation (answer_generation/twiga_runner.py)
# These are required by the Twiga app modules (app.database, app.services.*)
# that twiga_runner.py imports. Copy values from the original Twiga project's
# .env. Only needed if you're running answer generation, not pure evaluation.
# =============================================================================

# --- Twiga app environment ---
ENVIRONMENT=
BUSINESS_ENV=
DEBUG=

# --- Database ---
DATABASE_URL=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# --- LLM provider used inside the Twiga agent ---
LLM_PROVIDER=
LLM_MODEL_NAME=
LLM_API_KEY=

# --- Embedding provider used inside the Twiga agent ---
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=

# --- LangSmith tracing (optional — leave blank to disable) ---
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=

# --- WhatsApp / Meta ---
# twiga_runner.py mocks WhatsApp via unittest.mock, so these are typically
# not needed for answer generation. Filled in only if running the full app.
MOCK_WHATSAPP=
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_CLOUD_NUMBER_ID=
META_API_VERSION=
META_APP_ID=
META_APP_SECRET=
