# Twiga requires these environment variables.
# Copy this file to .env and fill in the values.

# --- Required by Twiga core ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/twiga
META_API_VERSION=v17.0
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
WHATSAPP_CLOUD_NUMBER_ID=your_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_API_TOKEN=your_whatsapp_api_token

# --- LLM settings ---
LLM_PROVIDER=TOGETHER          # TOGETHER | OPENAI | OLLAMA | MODAL | GOOGLE
LLM_API_KEY=your_llm_api_key
LLM_MODEL_NAME=Qwen/Qwen3-235B-A22B-Instruct-2507-tput

# --- Embedding settings ---
EMBEDDING_PROVIDER=TOGETHER     # TOGETHER | OPENAI | OLLAMA | MODAL
EMBEDDING_API_KEY=your_embedding_api_key

# --- Optional ---
MOCK_WHATSAPP=true
AGENTIC_MODE_ENABLED=true
